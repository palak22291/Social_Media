
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String ?
  email     String   @unique
  password  String
  posts     Post[]
  
  comments  Comment[]
  likes     Like[]

  
  followers Follower[] @relation("Followers")
  following Follower[] @relation("Following")

  refreshTokens  RefreshToken[]

  // chat
  conversationParticipants ConversationParticipant[]
  messages                 Message[]

}


model RefreshToken{

  id Int   @id @default(autoincrement())
  token  String  @unique
  userId  Int
  user   User  @relation(fields:[userId],references:[id], onDelete: Cascade)
  expiresAt DateTime
  createdAt  DateTime @default(now())
  revoked Boolean @default(false)
  replacedBy String?





}

model Follower {
  id          Int  @id @default(autoincrement())
  followerId  Int  
  followingId Int 

  follower   User @relation("Following", fields: [followerId], references: [id])  // I follow others
  following  User @relation("Followers", fields: [followingId], references: [id]) // others follow me

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}


model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  published Boolean @default(false)
  category String?
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
   comments  Comment[]

  likes Like[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index ([createdAt])
  @@index ([authorId])
  @@index ([published,createdAt])

}

model Comment {

   id        Int      @id @default(autoincrement())
  content   String
  authorId  Int
  postId    Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@index([postId])
  @@index([createdAt])

}

model Like{
   id       Int  @id @default(autoincrement())
  userId   Int
  postId   Int
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, postId])

  @@index([userId,postId])
  @@index([createdAt])
}


// ─── Chat ───────────────────────────────────────────────────────────────
// Group-first schema: a 1-on-1 DM is just a conversation with exactly two
// participants. Modelling groups from day one avoids a painful migration
// later when group chat is added.

model Conversation {
  id           Int                        @id @default(autoincrement())
  isGroup      Boolean                    @default(false)
  name         String?                    // group name; null for 1-on-1
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt   // bumped on new message, for sorting
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int
  userId         Int
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?    // for unread counts + read receipts
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])   // a user is in a conversation once
  @@index([userId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])   // for cursor-paginated history
}




